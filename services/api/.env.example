# App
NODE_ENV=development
PORT=3000

# Database (set one)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/guardiangate?schema=public
# SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-<region>.pooler.supabase.com:6543/postgres?uselibpqcompat=true&sslmode=require

# Auth and security
JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
QR_SECRET=replace-with-strong-qr-secret
# Set true to allow admin self-registration via /api/v1/auth/admin/signup
ENABLE_ADMIN_SIGNUP=true

# CORS
FRONTEND_ORIGIN=http://localhost:8080
CORS_ORIGINS=http://localhost:8080
SOCKET_CORS_ORIGINS=http://localhost:8080

# Provisioning defaults
DEFAULT_ADMIN_EMAIL=admin@guardian.com
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password

# Supabase API (backend only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional realtime provider (Pusher)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
