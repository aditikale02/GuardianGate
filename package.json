{
  "name": "guardian-gate",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev --workspace=@guardian/api",
    "dev:web": "npm run dev --workspace=@guardian/web",
    "dev:kiosk": "npm run dev --workspace=@guardian/kiosk",
    "dev:pwa": "npm run dev --workspace=@guardian/mobile-pwa",
    "dev:all": "npm run dev:api",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.19.0"
  }
}
